			"config": "simpleboats.client.mixins.json",
			"environment": "client"
		}
	],
    "accessWidener": "simpleboats.accesswidener",
	"depends": {
		"fabricloader": ">=0.18.1",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*"
	},
	"suggests": {
		"yet_another_config_lib_v3": ">=3.8.2"
