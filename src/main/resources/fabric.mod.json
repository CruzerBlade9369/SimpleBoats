{
	"schemaVersion": 1,
	"id": "simpleboats",
	"version": "${version}",
	"name": "Simple Boats",
	"description": "Vanilla-friendly alternatives to the humble boat.",
	"authors": [
		"Cruzer"
	],
	"contributors": [
		"Kimberstar",
		"Ghost"
	],
	"contact": {
		"homepage": "https://modrinth.com/mod/simple-boats",
		"sources": "https://github.com/CruzerBlade9369/SimpleBoats"
	},
	"license": "GPL-3.0",
	"icon": "assets/simpleboats/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
          "com.cruzer.simpleboats.SimpleBoats"
		],
		"client": [
          "com.cruzer.simpleboats.SimpleBoatsClient"
		],
