{
	"schemaVersion": 1,
	"id": "simpleboats",
	"version": "${version}",
	"name": "Simple Boats",
	"description": "Vanilla-friendly alternatives to the humble boat.",
	"authors": [
		"Cruzer"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "GPL-3.0",
	"icon": "assets/simpleboats/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
          "com.cruzer.simpleboats.SimpleBoats"
		],
		"client": [
          "com.cruzer.simpleboats.SimpleBoatsClient"
		],
      	"fabric-datagen": [
        "com.cruzer.simpleboats.datagen.SimpleBoatsDataGenerator"
      	],
		"modmenu": [
			"com.cruzer.simpleboats.client.config.SimpleBoatsModMenu"
		]
    },
	"mixins": [
		"simpleboats.mixins.json",
		{
			"config": "simpleboats.client.mixins.json",
			"environment": "client"
		}
	],
    "accessWidener": "simpleboats.accesswidener",
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "26.1.*",
		"java": ">=25",
		"fabric-api": "*",
		"yet_another_config_lib_v3": ">=3.9.3"
	},
	"suggests": {
		"another-mod": "*"
	}
}